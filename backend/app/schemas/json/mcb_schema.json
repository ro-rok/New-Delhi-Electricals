{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "MCB Product",
    "type": "object",
    "required": [
        "sku",
        "name",
        "product_family",
        "category",
        "subcategory",
        "brand",
        "specs",
        "pricing",
        "media",
        "seo",
        "status"
    ],
    "properties": {
        "sku": {
            "type": "string",
            "description": "Unique product identifier"
        },
        "name": {
            "type": "string",
            "description": "Product name"
        },
        "product_family": {
            "type": "string",
            "description": "Product family (e.g., Tripper)"
        },
        "category": {
            "type": "string",
            "const": "Circuit Protection"
        },
        "subcategory": {
            "type": "string",
            "description": "Product subcategory (e.g., Miniature Circuit Breakers (MCBs))"
        },
        "brand": {
            "type": "string",
            "description": "Brand name"
        },
        "specs": {
            "type": "object",
            "properties": {
                "ampere": {
                    "type": [
                        "number",
                        "null"
                    ],
                    "description": "Current rating in Amperes"
                },
                "curve": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "Tripping curve (e.g., C)"
                },
                "poles": {
                    "type": [
                        "number",
                        "null"
                    ],
                    "description": "Number of poles"
                },
                "mw": {
                    "type": [
                        "number",
                        "null"
                    ],
                    "description": "Module width (usually same as poles for MCBs)"
                }
            },
            "required": []
        },
        "variant": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "List of SKUs for product variants"
        },
        "pricing": {
            "type": "object",
            "required": [
                "mrp",
                "std_pack"
            ],
            "properties": {
                "mrp": {
                    "type": "number",
                    "description": "Maximum Retail Price"
                },
                "discount": {
                    "type": [
                        "number",
                        "null"
                    ],
                    "description": "Discount percentage or amount"
                },
                "selling_price": {
                    "type": [
                        "number",
                        "null"
                    ],
                    "description": "Final selling price"
                },
                "std_pack": {
                    "type": "string",
                    "description": "Standard pack quantity"
                }
            }
        },
        "media": {
            "type": "object",
            "properties": {
                "images": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "url": {
                                "type": "string"
                            },
                            "label": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "url",
                            "label"
                        ]
                    }
                },
                "documents": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "seo": {
            "type": "object",
            "required": [
                "slug",
                "meta_description"
            ],
            "properties": {
                "slug": {
                    "type": "string",
                    "description": "URL-friendly slug"
                },
                "keywords": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "meta_description": {
                    "type": "string",
                    "description": "SEO meta description"
                }
            }
        },
        "status": {
            "type": "object",
            "properties": {
                "is_active": {
                    "type": "boolean",
                    "default": true
                },
                "is_featured": {
                    "type": "boolean",
                    "default": false
                }
            }
        }
    }
}